# Transskriberingsmotor
# Sæt en gyldig OpenAI-nøgle for at bruge OpenAI Whisper API
OPENAI_API_KEY=
TRANSCRIPTION_ENGINE=openai
OPENAI_TRANSCRIPTION_MODEL=whisper-1
SUMMARY_MODEL=gpt-4o-mini

# Database
DATABASE_URL=sqlite:///./data/transskribering.db

# Filsystem
UPLOAD_DIRECTORY=./data/uploads
TEMP_DIRECTORY=./data/temp

# Begrænsninger
MAX_AUDIO_DURATION_SECONDS=7200
MAX_UPLOAD_SIZE_MB=500

# Opdeling af lyd
CHUNK_DURATION_SECONDS=900
CHUNK_OVERLAP_SECONDS=3

# Oprydning
# Værdier: immediate, 24h, 7d, never
AUDIO_RETENTION=24h

# Sprog (sendes til motoren)
DEFAULT_LANGUAGE=da

# Server
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
